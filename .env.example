# ╔═══════════════════════════════════════════════════════════════╗
# ║  QLCV — Environment variables template                         ║
# ║  Copy: cp .env.example .env  rồi điền giá trị thật            ║
# ║  KHÔNG commit .env (đã ignore trong .gitignore)                ║
# ╚═══════════════════════════════════════════════════════════════╝

# ── App ─────────────────────────────────────────────────────────
ENVIRONMENT=dev          # dev | staging | prod
DEBUG=false
LOG_LEVEL=INFO

# ── PostgreSQL ──────────────────────────────────────────────────
POSTGRES_USER=qlcv
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=qlcv
# Backend đọc DATABASE_URL — đã build sẵn trong docker-compose từ 3 biến trên.
# Khi chạy backend ngoài Docker (dev local), set thẳng:
# DATABASE_URL=postgresql+psycopg://qlcv:changeme@localhost:5437/qlcv

# ── Redis ───────────────────────────────────────────────────────
# Mặc định trong Docker stack: redis://qlcv_redis:6379/0
# Khi chạy local: redis://localhost:6380/0

# ── Master key mã hoá phong bì (TDD §3.4) ──────────────────────
# 32 byte = 64 ký tự hex. Sinh bằng:
#     python -c "import secrets; print(secrets.token_hex(32))"
# CẢNH BÁO: mất master key = mất truy cập toàn bộ file đã mã hoá.
MASTER_KEY_HEX=

# ── Cloudflare R2 (storage lạnh) ────────────────────────────────
R2_ENDPOINT=https://<account>.r2.cloudflarestorage.com
R2_BUCKET=qlcv-storage
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# ── Web Push (VAPID — TDD L1) ───────────────────────────────────
# Sinh cặp khoá: npx web-push generate-vapid-keys --json
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@thanhdat.example

# ── Sentry (TDD §13) ────────────────────────────────────────────
SENTRY_DSN=

# ── CORS (chỉ cần khi FE dev tách port 5173) ───────────────────
# Production thì FE serve cùng domain qua Nginx → bỏ trống.
# CORS_ORIGINS=["http://localhost:5173"]
